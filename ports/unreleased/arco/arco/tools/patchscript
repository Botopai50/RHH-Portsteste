#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1
echo "GAMEDIR is set to: $GAMEDIR"

# Patch failure function
patch_failure() {
    # Exit script, or return if sourced
    return 1 2>/dev/null || exit 1
}

# Exports
export PATH="$GAMEDIR/tools:$PATH"
export LD_LIBRARY_PATH="$LD_LIBRARY_PATH"
export SDL_GAMECONTROLLERCONFIG="$sdl_controllerconfig"
export DATAFILE="arco.exe"
export TMPDIR="$GAMEDIR/tmp"

# Permissions
chmod 666 /dev/uinput

cd "$GAMEDIR"

# Set up trap for cleaning TMPDIR on exit
trap 'rm -rf "$TMPDIR"' 0

# Test for commands: python, zip
PYTHON=$(command -v python3)
if [ -z "$PYTHON" ]; then
    echo "Missing Python!"
    patch_failure
fi

ZIP=$(command -v zip)
if [ -z "$ZIP" ]; then
    echo "Missing zip!"
    patch_failure
fi

extract_assets() {
    if [ ! -f "$DATAFILE" ]; then
        echo "Error: $DATAFILE not found in $GAMEDIR"
        return 1
    fi

    echo "Extracting full LÖVE archive..."
    mkdir -p "$TMPDIR"

    # Use 7za to extract everything
    "$GAMEDIR/tools/7za" x "$DATAFILE" -o"$TMPDIR" -y > /dev/null || {
        echo "Failed to extract archive"
        return 1
    }

    echo "Assets extracted to $TMPDIR"
}

compress_audio() {
    mkdir -p "$TMPDIR"
    if "$PYTHON" tools/compress-audio.py "$TMPDIR" -d "$TMPDIR" -m 1000 -b 64 -D -y; then
        echo "Audio recompression complete"
    else
        echo "Audio recompression failed"
        return 1
    fi
}

zip_archive() {
    cd "$TMPDIR" || { echo "TMPDIR missing"; return 1; }

    # Repack everything into a new .love archive
    "$GAMEDIR/tools/7za" a -tzip "$GAMEDIR/$DATAFILE" ./* -mx=9 > /dev/null || {
        echo "Failed to rebuild game.love"
        return 1
    }

    echo "$DATAFILE successfully updated with recompressed audio."
}

process_game() {
    extract_assets || { patch_failure; return 1; }

    echo "Compressing audio..."
    compress_audio || { patch_failure; return 1; }

    echo "Finishing up..."
    zip_archive || { patch_failure; return 1; }
}

# Call the function
if ! process_game; then
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi
