#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
rm -f "$GAMEDIR/$LOGERR"
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}

echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/assets"
export DATAFILE="soniccolors.port"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    # Test for python
    PYTHON=$(command -v python3)
    if [ -z "$PYTHON" ]; then
        emit_fail_msg "Missing Python!"
        return 1
    fi

    ZIP=$(command -v zip)
    if [ -z "$ZIP" ]; then
        emit_fail_msg "Missing zip!"
        return 1
    fi

    # Mount the GMToolkit runtime
    TOOLKIT="$HOME/gmtoolkit"
    RUNTIME="$controlfolder/libs/gmtoolkit.squashfs"
    if [ -f "$RUNTIME" ]; then
        $ESUDO mkdir -p "$TOOLKIT"
        $ESUDO umount "$TOOLKIT" 2>/dev/null || true
        $ESUDO mount "$RUNTIME" "$TOOLKIT"
    else
        emit_fail_msg "This port requires the GMToolkit runtime. Please download it."
        return 1
    fi

    # Mount the dotnet runtime
    DOTNETDIR="$HOME/mono"
    DOTNETFILE="$controlfolder/libs/dotnet-8.0.12.squashfs"
    if [ -f "$DOTNETFILE" ]; then
        $ESUDO mkdir -p "$DOTNETDIR"
        $ESUDO umount "$DOTNETDIR" 2>/dev/null || true
        $ESUDO mount "$DOTNETFILE" "$DOTNETDIR"
    else
        emit_fail_msg "This port requires the Dotnet runtime. Please download it."
        return 1
    fi

    # Attempt to get SAVEDIR from gmloader.json using jq
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
    else
        SAVEDIR="$GAMEDIR/saves"
    fi

    # Exports
    export PYTHON
    export ZIP
    export SAVEDIR
    export PATH="$DOTNETDIR:$TOOLKIT/gmtools:$TOOLKIT/utmt-cli:$PATH"
    export LD_LIBRARY_PATH="/usr/lib:$TOOLKIT/libs:$LD_LIBRARY_PATH"
    export SDL_GAMECONTROLLERCONFIG="$sdl_controllerconfig"

    # These exports help dotnet save memory and hopefully eliminate oomkill issues during patching
    export DOTNET_gcServer=0
    export DOTNET_gcLatencyLevel=SustainedLowLatency
    export DOTNET_GCHighMemPercent=50

    # Permissions
    chmod 666 /dev/uinput
}

prepare_files() {
    # Delete unnecessary files
    rm -rf "$DATADIR"/*.exe "$DATADIR"/*.dll "$DATADIR/.gitkeep"
    echo "Removed unnecessary files"
}

# Externalize game textures with compression
dump_textures() {
    # Purge cache before operations
    rm -rf "$TMPDIR/"*

    # Begin texture operations
    dotnet "$TOOLKIT/utmt-cli/UndertaleModCli.dll" \
        dump "$DATADIR/data.win" \
        -e "$DATADIR/textures" "$DATADIR/game.droid"

    if [ $? -ne 0 ]; then
        emit_fail_msg "[DOTNET]: Texture dumping failed to apply."
        return 1
    else
        rm -f "$DATADIR/data.win"
        mkdir -p "$SAVEDIR"
        mv "$DATADIR/textures" "$SAVEDIR/textures"
        if [ -n "$TMPDIR" ] && [ -d "$TMPDIR" ]; then
            rm -rf "$TMPDIR"/*
        fi
    fi
}

compress_audio() {
    # Do audio compression
    if $PYTHON "$TOOLKIT/gmtools/gmKtool.py" -vv -m 1000 -r -b 64 -d "$TMPDIR" "$DATADIR/game.droid"; then
        mv "$TMPDIR/"* "$DATADIR" && rmdir "$TMPDIR"
        echo "Audio compression applied successfully."
    else
        # Failure
        emit_fail_msg "Audio compression failed."
        rmdir "$TMPDIR" 2>/dev/null || true
        return 1
    fi
}

zip_archive() {
    $ZIP -r -0 "$DATAFILE" ./assets/
    rm -rf "$DATADIR/"*
}

# Cleanup
cleanup() {
    rm -rf "$TMPDIR"
    $ESUDO umount "$DOTNETDIR" 2>/dev/null || true
    $ESUDO umount "$TOOLKIT" 2>/dev/null || true
}

process_game() {
    echo "Preparing system..."
    prepare_system || { cleanup; return 1; }
    echo "Preparing game..."
    prepare_files || { cleanup; return 1; }
    echo "Externalizing textures..."
    dump_textures || { cleanup; return 1; }
    echo "Compressing audio..."
    compress_audio || { cleanup; return 1; }
    echo "Finishing up..."
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi

# Always run cleanup at the end
cleanup
