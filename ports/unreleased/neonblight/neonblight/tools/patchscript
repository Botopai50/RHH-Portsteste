#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
rm -f "$GAMEDIR/$LOGERR"
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
}

# Default failure-dialog message; overridden at specific failure points below.
emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/gamedata"
export DATAFILE="$GAMEDIR/game.apk"
export TOOLDIR="$GAMEDIR/tools"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    # Test for python
    PYTHON=$(command -v python3)
    if [ -z "$PYTHON" ]; then
        emit_fail_msg "Missing Python!"
        return 1
    fi

    ZIP=$(command -v zip)
    if [ -z "$ZIP" ]; then
        emit_fail_msg "Missing zip!"
        return 1
    fi

    XDELTA=$(command -v xdelta3)
    if [ -z "$XDELTA" ]; then
        emit_fail_msg "Missing xdelta3!"
        return 1
    fi

    # Exports
    export PYTHON
    export ZIP
    export XDELTA
    export PATH="$TOOLDIR:$PATH"
    export LD_LIBRARY_PATH="/usr/lib:$GAMEDIR/lib:$TOOLDIR/libs:$LD_LIBRARY_PATH"
    export SDL_GAMECONTROLLERCONFIG="$sdl_controllerconfig"

    # Permissions
    chmod 666 /dev/uinput
    chmod 777 "$TOOLDIR/gmKtool.py"
    chmod 777 "$TOOLDIR/oggenc"
}

apply_xdelta() {
    # Check if the data.win file exists and apply xdelta
    if [ -f "$DATADIR/data.win" ]; then
        echo "Applying xdelta patch"
        output=$($XDELTA -d -s "$DATADIR/data.win" -f "$TOOLDIR/patches/neon.xdelta" "$DATADIR/game.droid" 2>&1)
        if [ $? -eq 0 ]; then
            echo "Patch applied successfully"
            echo "$output"
            rm -f "$DATADIR/data.win"
        else
            emit_fail_msg "Failed to apply xdelta patch."
            echo "$output"
            return 1
        fi
    fi
}

prepare_files() {
    # Delete unnecessary files
    rm -rf "$DATADIR"/*.exe "$DATADIR"/*.dll "$DATADIR/.gitkeep"
    echo "Removed unnecessary files"

    # If apply_xdelta didn't already produce game.droid, rename data.win
    if [ -f "$DATADIR/data.win" ] && [ ! -f "$DATADIR/game.droid" ]; then
        mv "$DATADIR/data.win" "$DATADIR/game.droid"
    fi
}

compress_audio() {
    echo "Compressing audio..."
    mkdir -p "$TMPDIR"

    $PYTHON "$TOOLDIR/gmKtool.py" -vvv -m 1000 -r -b 64 -d "$TMPDIR" "$DATADIR/game.droid"

    if [ $? -eq 0 ]; then
        echo "Compression completed successfully."
        mv "$TMPDIR/"* "$DATADIR"
        echo "Moved compressed files to $DATADIR."
        rmdir "$TMPDIR"
        echo "Audio compression applied successfully."
    else
        emit_fail_msg "Audio compression failed."
        rm -rf "$TMPDIR"
        return 1
    fi
}

zip_archive() {
    # Move any .dat files into assets/ and zip into the APK
    if [ -n "$(ls "$DATADIR"/*.dat 2>/dev/null)" ]; then
        mkdir -p "$GAMEDIR/assets"
        mv "$DATADIR"/*.dat "$GAMEDIR/assets/"
        echo "Moved .dat files to assets/"

        $ZIP -r -0 "$DATAFILE" "$GAMEDIR/assets/"
        echo "Zipped contents to $DATAFILE"

        rm -rf "$GAMEDIR/assets"
    else
        echo "No .dat files found."
    fi
}

# Cleanup
cleanup() {
    rm -rf "$TMPDIR"
}

process_game() {
    echo "Preparing system..."
    prepare_system || { cleanup; return 1; }
    echo "Applying patch..."
    apply_xdelta || { cleanup; return 1; }
    echo "Preparing game..."
    prepare_files || { cleanup; return 1; }
    echo "Compressing audio..."
    compress_audio || { cleanup; return 1; }
    echo "Finishing up..."
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi

# Always run cleanup at the end
cleanup
