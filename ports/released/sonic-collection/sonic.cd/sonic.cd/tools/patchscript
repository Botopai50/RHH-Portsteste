#!/bin/sh

GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Logging
rm -f "$GAMEDIR/$LOGERR"
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
}

# Default failure-dialog message; overridden at specific failure points below.
emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
echo "GAMEDIR is set to: $GAMEDIR"

TARGET="$GAMEDIR/Data.rsdk"
ORIGINS="$GAMEDIR/SonicCDu.rsdk"
DATADIR="$GAMEDIR/Data"
TMPDIR="$GAMEDIR/tmp"
MUSICDIR="$DATADIR/Music"
SFXDIR="$DATADIR/SoundFX"
TOOLSDIR="$GAMEDIR/tools"

# Audio pack source files — user drops these in $GAMEDIR.
MUSIC_ACB="$GAMEDIR/SCD_music.acb"
MUSIC_AWB="$GAMEDIR/SCD_music.awb"
SFX_ACB="$GAMEDIR/SCD_sfx.acb"
HITE_ACB="$GAMEDIR/HITE_sfx.acb"

# HCA keycodes per https://rsdkmodding.com/Games/SonicOrigins/Documentation/Audio/
SCD_MUSIC_KEY="15760211266427465005"
SCD_SFX_KEY="13112347560991493607"
HITE_SFX_KEY="1441441318033510872"

EXTRACTOR="$TOOLSDIR/rsdkv5u-extract"
FILELIST="$TOOLSDIR/RSDKv5UFileList.txt"
VGMSTREAM="$TOOLSDIR/vgmstream-cli"
OGGENC="$TOOLSDIR/oggenc"
NORMALIZE="$TOOLSDIR/wav-normalize"

# Origins SFX are mastered ~8dB quieter than mobile. Normalize to -3dBFS.
SFX_TARGET_DBFS="-3"

# === Pre-flight: fail loudly if inputs are incomplete ===
# Accepted starting states:
#   A) Origins bundle: SonicCDu.rsdk + SCD_music.acb/awb + SCD_sfx.acb + HITE_sfx.acb
#   B) Mobile-only pass-through: Data.rsdk already mobile-signed (RSDKvB)
#   C) Already-extracted pass-through: Data/Game/GameConfig.bin exists
check_inputs() {
    if [ -f "$DATADIR/Game/GameConfig.bin" ]; then
        echo "Existing extracted Data/ detected — no new drops to process."
        return 0
    fi
    if [ -f "$TARGET" ]; then
        sig=$(dd if="$TARGET" bs=1 count=6 2>/dev/null)
        case "$sig" in
            RSDKvB)
                echo "Mobile Data.rsdk detected — engine will load it directly."
                return 0
                ;;
            RSDKv3|RSDKv4|RSDKv5)
                emit_fail_msg "Data.rsdk has Origins/decomp signature '$sig'. Rename to SonicCDu.rsdk and also provide SCD_music.acb, SCD_music.awb, SCD_sfx.acb, HITE_sfx.acb."
                return 1
                ;;
            *)
                emit_fail_msg "ERROR: Data.rsdk has unrecognized signature: '$sig'"
                return 1
                ;;
        esac
    fi

    missing=""
    [ -f "$ORIGINS" ]   || missing="${missing}  SonicCDu.rsdk\n"
    [ -f "$MUSIC_ACB" ] || missing="${missing}  SCD_music.acb\n"
    [ -f "$MUSIC_AWB" ] || missing="${missing}  SCD_music.awb\n"
    [ -f "$SFX_ACB" ]   || missing="${missing}  SCD_sfx.acb\n"
    [ -f "$HITE_ACB" ]  || missing="${missing}  HITE_sfx.acb\n"
    if [ -n "$missing" ]; then
        echo "ERROR: missing required files in $GAMEDIR:"
        printf "$missing"
        echo ""
        echo "This port needs the following from Sonic Origins:"
        echo "  SonicCDu.rsdk    — image/x64/raw/retro/SonicCDu.rsdk"
        echo "  SCD_music.acb    — image/x64/raw/sound/SCD_music.acb"
        echo "  SCD_music.awb    — image/x64/raw/sound/SCD_music.awb"
        echo "  SCD_sfx.acb      — image/x64/raw/sound/SCD_sfx.acb"
        echo "  HITE_sfx.acb     — image/x64/raw/sound/HITE_sfx.acb"
        echo ""
        emit_fail_msg "Missing required files from Sonic Origins. See patcherr.txt for the list, then drop them into this folder and relaunch."
        return 1
    fi
    return 0
}

check_tools() {
    [ -f "$EXTRACTOR" ] && $ESUDO chmod +x "$EXTRACTOR" 2>/dev/null
    [ -f "$VGMSTREAM" ] && $ESUDO chmod +x "$VGMSTREAM" 2>/dev/null
    [ -f "$OGGENC" ]    && $ESUDO chmod +x "$OGGENC"    2>/dev/null
    [ -f "$NORMALIZE" ] && $ESUDO chmod +x "$NORMALIZE" 2>/dev/null

    missing=""
    [ -x "$EXTRACTOR" ] || missing="${missing}  tools/rsdkv5u-extract\n"
    [ -f "$FILELIST" ]  || missing="${missing}  tools/RSDKv5UFileList.txt\n"
    [ -x "$VGMSTREAM" ] || missing="${missing}  tools/vgmstream-cli\n"
    [ -x "$OGGENC" ]    || missing="${missing}  tools/oggenc\n"
    [ -x "$NORMALIZE" ] || missing="${missing}  tools/wav-normalize\n"
    if [ -n "$missing" ]; then
        echo "ERROR: port is missing required helper tools:"
        printf "$missing"
        emit_fail_msg "Reinstall the port."
        return 1
    fi
    return 0
}

extract_rsdk() {
    [ -f "$ORIGINS" ] || return 0

    echo "Extracting Origins SonicCDu.rsdk..."
    if ! "$EXTRACTOR" "$ORIGINS" "$FILELIST" "$GAMEDIR"; then
        emit_fail_msg "ERROR: SonicCDu.rsdk extraction failed."
        return 1
    fi
    if [ ! -f "$DATADIR/Game/GameConfig.bin" ]; then
        emit_fail_msg "ERROR: extraction produced no GameConfig.bin."
        return 1
    fi
    rm -f "$ORIGINS" "$TARGET"
    echo "Origins data extracted to Data/."
}

