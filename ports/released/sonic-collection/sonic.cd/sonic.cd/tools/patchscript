# Origins SCD music cue name -> relative path in Data/Music/. SCD has a dual
# JP/US soundtrack (user picks at Jukebox). Tracks with _J suffix go to JP/,
# _E suffix go to US/, and PCM*_R?B (past/B-side) go to Music/ root since
# mobile uses a single copy for both regions.
map_music_name() {
    case "$1" in
        # PAST/B-side tracks (shared between regions) -> Music/ root
        *PCM10_R1B)               echo R1B.ogg ;;
        *PCM11_R3B)               echo R3B.ogg ;;
        *PCM12_R4B)               echo R4B.ogg ;;
        *PCM13_R5B)               echo R5B.ogg ;;
        *PCM14_R6B)               echo R6B.ogg ;;
        *PCM15_R7B)               echo R7B.ogg ;;
        *PCM16_R8B)               echo R8B.ogg ;;
        # JP zone tracks
        *_R1A_J)                  echo JP/R1A.ogg ;;
        *_R1C_J)                  echo JP/R1C.ogg ;;
        *_R1D_J)                  echo JP/R1D.ogg ;;
        *_R3A_J)                  echo JP/R3A.ogg ;;
        *_R3C_J)                  echo JP/R3C.ogg ;;
        *_R3D_J)                  echo JP/R3D.ogg ;;
        *_R4A_J)                  echo JP/R4A.ogg ;;
        *_R4C_J)                  echo JP/R4C.ogg ;;
        *_R4D_J)                  echo JP/R4D.ogg ;;
        *_R5A_J)                  echo JP/R5A.ogg ;;
        *_R5C_J)                  echo JP/R5C.ogg ;;
        *_R5D_J)                  echo JP/R5D.ogg ;;
        *_R6A_J)                  echo JP/R6A.ogg ;;
        *_R6C_J)                  echo JP/R6C.ogg ;;
        *_R6D_J)                  echo JP/R6D.ogg ;;
        *_R7A_J)                  echo JP/R7A.ogg ;;
        *_R7C_J)                  echo JP/R7C.ogg ;;
        *_R7D_J)                  echo JP/R7D.ogg ;;
        *_R8A_J)                  echo JP/R8A.ogg ;;
        *_R8C_J)                  echo JP/R8C.ogg ;;
        *_R8D_J)                  echo JP/R8D.ogg ;;
        *_Boss_J)                 echo JP/Boss.ogg ;;
        *_FinalBoss_J)            echo JP/FinalBoss.ogg ;;
        *_SpecialStage_J)         echo JP/SpecialStage.ogg ;;
        *_DAGarden_J)             echo JP/DAGarden.ogg ;;
        *_ZoneComplete_J)         echo JP/ZoneComplete.ogg ;;
        *_SpeedShoes_J)           echo JP/SpeedShoes.ogg ;;
        *_Invincibility_J)        echo JP/Invincibility.ogg ;;
        *_GameOver_J)             echo JP/GameOver.ogg ;;
        # TitleScreen is a compound cue (DA26 + DA27 in one stream) for US,
        # and a single DA32 in JP. Route both to {region}/TitleScreen.ogg.
        *_TitleScreen_J)          echo JP/TitleScreen.ogg ;;
        RSDK_SCD_J*TimeAttack)    echo JP/TimeAttack.ogg ;;
        # US/EU zone tracks
        *_R1A_E)                  echo US/R1A.ogg ;;
        *_R1C_E)                  echo US/R1C.ogg ;;
        *_R1D_E)                  echo US/R1D.ogg ;;
        *_R3A_E)                  echo US/R3A.ogg ;;
        *_R3C_E)                  echo US/R3C.ogg ;;
        *_R3D_E)                  echo US/R3D.ogg ;;
        *_R4A_E)                  echo US/R4A.ogg ;;
        *_R4C_E)                  echo US/R4C.ogg ;;
        *_R4D_E)                  echo US/R4D.ogg ;;
        *_R5A_E)                  echo US/R5A.ogg ;;
        *_R5C_E)                  echo US/R5C.ogg ;;
        *_R5D_E)                  echo US/R5D.ogg ;;
        *_R6A_E)                  echo US/R6A.ogg ;;
        *_R6C_E)                  echo US/R6C.ogg ;;
        *_R6D_E)                  echo US/R6D.ogg ;;
        *_R7A_E)                  echo US/R7A.ogg ;;
        *_R7C_E)                  echo US/R7C.ogg ;;
        *_R7D_E)                  echo US/R7D.ogg ;;
        *_R8A_E)                  echo US/R8A.ogg ;;
        *_R8C_E)                  echo US/R8C.ogg ;;
        *_R8D_E)                  echo US/R8D.ogg ;;
        *_Boss_E)                 echo US/Boss.ogg ;;
        *_FinalBoss_E)            echo US/FinalBoss.ogg ;;
        *_DAGarden_E)             echo US/DAGarden.ogg ;;
        *_ZoneComplete_E)         echo US/ZoneComplete.ogg ;;
        *_SpeedShoes_E)           echo US/SpeedShoes.ogg ;;
        *_Invincibility_E)        echo US/Invincibility.ogg ;;
        *_GameOver_E)             echo US/GameOver.ogg ;;
        *_TitleScreen_E*)         echo US/TitleScreen.ogg ;;
        # US TimeAttack — Origins only ships the JP version with the
        # RSDK_SCD_J prefix. Routed above. US engine will play JP track as
        # fallback (no crash; mobile ships both but content is identical).
        # Opening/Ending FMV tracks — handled by theoraplay in the video
        # path, not as Data/Music files. Skip.
        *_Opening*|*_Ending*)     echo "" ;;
        *) echo "" ;;
    esac
}

# place_sfx <tmp_wav> <relative_target>
# Normalize + move to $SFXDIR/$target. SCD audio is all .wav (unlike S2
# which has .ogg Globals), so the normalize-to-wav path is always used.
place_sfx() {
    src="$1"; rel="$2"
    dst="$SFXDIR/$rel"
    mkdir -p "$(dirname "$dst")"
    if "$NORMALIZE" "$SFX_TARGET_DBFS" "$src" "$dst" 2>/dev/null; then
        rm -f "$src"
        return 0
    fi
    mv -f "$src" "$dst" || return 1
    return 0
}

extract_music() {
    [ -f "$MUSIC_AWB" ] || return 0

    echo "$SCD_MUSIC_KEY" > "$GAMEDIR/SCD_music.hcakey"
    mkdir -p "$TMPDIR" "$MUSICDIR/JP" "$MUSICDIR/US"
    rm -f "$TMPDIR"/*.wav 2>/dev/null

    size=$(wc -c <"$MUSIC_AWB")
    echo "Extracting SCD_music.awb ($((size / 1048576)) MB — larger Remastered/Hardware variants can take several minutes)..."
    if ! "$VGMSTREAM" -S -1 -o "$TMPDIR/?s_?n.wav" "$MUSIC_AWB" >/dev/null; then
        emit_fail_msg "ERROR: vgmstream-cli failed on music."
        rm -f "$GAMEDIR/SCD_music.hcakey"
        return 1
    fi
    rm -f "$GAMEDIR/SCD_music.hcakey"

    total=$(ls "$TMPDIR"/*.wav 2>/dev/null | wc -l)
    echo "Encoding $total tracks to OGG and placing in Music/..."
    count=0
    skipped=0
    for wav in "$TMPDIR"/*.wav; do
        [ -f "$wav" ] || continue
        base=$(basename "$wav" .wav)
        target=$(map_music_name "$base")
        if [ -z "$target" ]; then
            skipped=$((skipped + 1))
            continue
        fi
        mkdir -p "$MUSICDIR/$(dirname "$target")"
        if "$OGGENC" -Q -q 5 --discard-comments -o "$MUSICDIR/$target" "$wav" 2>/dev/null; then
            count=$((count + 1))
            # Progress dot every 5 tracks so the patcher UI looks alive.
            [ $((count % 5)) -eq 0 ] && printf "."
        else
            echo "WARNING: failed to encode $base -> $target"
        fi
    done
    echo "Encoded $count tracks ($skipped unmapped)."

    rm -f "$MUSIC_AWB" "$MUSIC_ACB"
    rm -f "$TMPDIR"/*.wav
}

extract_sfx() {
    [ -f "$SFX_ACB" ] || return 0

    echo "$SCD_SFX_KEY" > "$GAMEDIR/SCD_sfx.hcakey"
    mkdir -p "$TMPDIR" "$SFXDIR/Global" "$SFXDIR/Stage"
    rm -f "$TMPDIR"/*.wav 2>/dev/null

    echo "Extracting SCD_sfx.acb..."
    # -S -1 enumerates all subsongs. Vanilla Origins has 99, Ultrafix has 106
    # (the extra 7 include the P03/P06/P07 Amy cues). Filenames come out as
    # "<subsong>_<cue>.wav" — our *_CueName globs below still match.
    if ! "$VGMSTREAM" -S -1 -o "$TMPDIR/?s_?n.wav" "$SFX_ACB" >/dev/null; then
        emit_fail_msg "ERROR: vgmstream-cli failed on SFX."
        rm -f "$GAMEDIR/SCD_sfx.hcakey"
        return 1
    fi
    rm -f "$GAMEDIR/SCD_sfx.hcakey"

    echo "Placing SFX in SoundFX/..."
    count=0
    skipped=0
    for wav in "$TMPDIR"/*.wav; do
        [ -f "$wav" ] || continue
        base=$(basename "$wav" .wav)
        # Strip the "<subsong>_" prefix that vgmstream's -S -1 adds to each
        # output file, so our case patterns match on bare cue names.
        base="${base#[0-9]*_}"

        # Vanilla Origins ships F73 and P04 as ONE compound cue, joined by
        # "; " in the filename — same audio plays both Achievement and 1Up.
        # Ultrafix's SCD_sfx.acb splits them: F73 is the 3.8s Achievement
        # fanfare, P04 is the 0.4s 1Up ding (distinct audio).
        case "$base" in
            *"; "*SFX_SCD_P04_1Up|SFX_SCD_F73_Achievement*"; "*)
                # Vanilla compound cue — copy to both targets.
                cp "$wav" "${wav}.dup.wav"
                if place_sfx "$wav" "Global/Achievement.wav"; then
                    count=$((count + 1))
                fi
                if place_sfx "${wav}.dup.wav" "Global/1Up.wav"; then
                    count=$((count + 1))
                fi
                continue
                ;;
            SFX_SCD_F73_Achievement)
                # Ultrafix: standalone Achievement.
                if place_sfx "$wav" "Global/Achievement.wav"; then
                    count=$((count + 1))
                fi
                continue
                ;;
            SFX_SCD_P04_1Up)
                # Ultrafix: standalone 1Up.
                if place_sfx "$wav" "Global/1Up.wav"; then
                    count=$((count + 1))
                fi
                continue
                ;;
        esac

        target=$(map_sfx_name "$base")
        if [ -z "$target" ]; then
            skipped=$((skipped + 1))
            continue
        fi
        if place_sfx "$wav" "$target"; then
            count=$((count + 1))
        else
            echo "WARNING: failed to place $base -> $target"
        fi
    done
    echo "Placed $count SFX ($skipped unmapped)."

    rm -f "$SFX_ACB"
    rm -f "$TMPDIR"/*.wav
}

# HITE_sfx just for the SEGA chant (Title stage references Stage/Sega.wav).
extract_hite() {
    [ -f "$HITE_ACB" ] || return 0

    echo "$HITE_SFX_KEY" > "$GAMEDIR/HITE_sfx.hcakey"
    mkdir -p "$TMPDIR" "$SFXDIR/Stage"
    rm -f "$TMPDIR"/*.wav 2>/dev/null

    echo "Extracting HITE_sfx.acb..."
    if ! "$VGMSTREAM" -S 0 -o "$TMPDIR/?n.wav" "$HITE_ACB" >/dev/null; then
        emit_fail_msg "ERROR: vgmstream-cli failed on HITE SFX."
        rm -f "$GAMEDIR/HITE_sfx.hcakey"
        return 1
    fi
    rm -f "$GAMEDIR/HITE_sfx.hcakey"

    wav="$TMPDIR/SFX_07_SEGA.wav"
    if [ ! -f "$wav" ]; then
        echo "WARNING: SFX_07_SEGA cue missing"
    elif place_sfx "$wav" "Stage/Sega.wav"; then
        echo "Placed Stage/Sega.wav"
    else
        echo "WARNING: failed to place Sega.wav"
    fi

    rm -f "$HITE_ACB"
    rm -f "$TMPDIR"/*.wav
}

cleanup() {
    rm -rf "$TMPDIR"
}

process_game() {
    check_tools   || { cleanup; return 1; }
    check_inputs  || { cleanup; return 1; }
    extract_rsdk  || { cleanup; return 1; }
    extract_music || { cleanup; return 1; }
    extract_sfx   || { cleanup; return 1; }
    extract_hite  || { cleanup; return 1; }
    cleanup
}

if ! process_game; then
    echo "Patching process failed!"
    mv "$GAMEDIR/$LOGFILE" "$GAMEDIR/$LOGERR"
else
    echo "Patching process complete!"
fi
