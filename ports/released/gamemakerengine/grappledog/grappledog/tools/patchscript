#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
rm -f "$GAMEDIR/$LOGERR"
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}

echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/assets"
export LICENSEDIR="$GAMEDIR/licenses/grappledog"
export DATAFILE="grappledog.port"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    ZIP=$(command -v zip)
    if [ -z "$ZIP" ]; then
        emit_fail_msg "Missing zip!"
        return 1
    fi

    PYTHON=$(command -v python3 || command -v python)
    if [ -z "$PYTHON" ]; then
        emit_fail_msg "Missing python3!"
        return 1
    fi

    ASTCENC="$controlfolder/astcenc.${DEVICE_ARCH}"
    if [ ! -x "$ASTCENC" ]; then
        emit_fail_msg "astcenc binary not found at $ASTCENC"
        return 1
    fi

    # Resolve SAVEDIR from gmloader.json; ensure it's absolute under GAMEDIR.
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR_REL=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
        SAVEDIR="$GAMEDIR/${SAVEDIR_REL:-saves}"
    else
        SAVEDIR="$GAMEDIR/saves"
    fi
    export PYTHON ASTCENC SAVEDIR
}

prepare_assets() {
    # Delete files we don't need
    rm -rf "$DATADIR"/*.exe "$DATADIR"/*.dll "$DATADIR"/.gitkeep "$DATADIR"/grappledog_data

    mkdir -p "$SAVEDIR" "$LICENSEDIR"
    [ -d "$DATADIR/fmodBanks" ] && mv "$DATADIR/fmodBanks" "$SAVEDIR/fmodBanks"
    [ -d "$DATADIR/licenses" ] && mv "$DATADIR/licenses/"* "$LICENSEDIR"
    rmdir "$DATADIR/licenses" 2>/dev/null || true
}

externalize_textures() {
    mkdir -p "$SAVEDIR/textures" "$TMPDIR"
    echo "Extracting textures and compressing..."
    if ! $PYTHON "$GAMEDIR/tools/extract_2zoq.py" \
            "$DATADIR/data.win" "$SAVEDIR/textures" \
            --astcenc "$ASTCENC" \
            --quality=-medium \
            --tmpdir "$TMPDIR"; then
        emit_fail_msg "Texture compression failed."
        return 1
    fi
}

# Add assets to $DATAFILE
zip_archive() {
        echo "Finishing up..."
        [ -f "$DATADIR/data.win" ] && mv "$DATADIR/data.win" "$DATADIR/game.droid"
        zip -r -0 "$DATAFILE" ./assets/
        rm -rf "$DATADIR"/*
        sleep 1
}

cleanup() {
    rm -rf "$TMPDIR"
}

process_game() {
    prepare_system || { cleanup; return 1; }
    prepare_assets || { cleanup; return 1; }
    externalize_textures || { cleanup; return 1; }
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi

cleanup
