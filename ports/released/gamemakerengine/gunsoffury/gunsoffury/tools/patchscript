#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
rm -f "$GAMEDIR/$LOGERR"
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}

echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/assets"
export DATAFILE="gunsoffury.port"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    # Test for commands: python, zip
    PYTHON=$(command -v python3)
    if [ -z "$PYTHON" ]; then
        emit_fail_msg "Missing Python!"
        return 1
    fi
    
    # Mount the GMToolkit runtime
    TOOLKIT="$HOME/gmtoolkit"
    RUNTIME="$controlfolder/libs/gmtoolkit.squashfs"
    if [ -f "$RUNTIME" ]; then
        $ESUDO mkdir -p "$TOOLKIT"
        $ESUDO umount "$TOOLKIT" 2>/dev/null || true
        $ESUDO mount "$RUNTIME" "$TOOLKIT"
    else
        emit_fail_msg "This port requires the GMToolkit runtime. Please download it."
        return 1
    fi

    # Mount the dotnet runtime
    DOTNETDIR="$HOME/mono"
    DOTNETFILE="$controlfolder/libs/dotnet-8.0.12.squashfs"
    if [ -f "$DOTNETFILE" ]; then
        $ESUDO mkdir -p "$DOTNETDIR"
        $ESUDO umount "$DOTNETDIR" 2>/dev/null || true
        $ESUDO mount "$DOTNETFILE" "$DOTNETDIR"
    else
        emit_fail_msg "This port requires the Dotnet runtime. Please download it."
        return 1
    fi
    
    # Attempt to get SAVEDIR from gmloader.json using jq
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
    else
        SAVEDIR="$GAMEDIR/saves"
    fi
    
    # Exports
    export PYTHON
    export SAVEDIR
    export PATH="$DOTNETDIR:$TOOLKIT/gmtools:$TOOLKIT/utmt-cli:$PATH"
    export LD_LIBRARY_PATH="/usr/lib:$TOOLKIT/libs:$LD_LIBRARY_PATH"

    # These exports help dotnet save memory and hopefully eliminate oomkill issues during patching
    export DOTNET_gcServer=0
    export DOTNET_gcLatencyLevel=SustainedLowLatency
    export DOTNET_GCHighMemPercent=50
}

prepare_files() {
    mkdir -p "$SAVEDIR"
    
    # Delete excess files
    find "$DATADIR" -type f \( \
        -name "*.gitkeep" -o -name "*.exe" -o -name "*.dll" -o -name "*.hashdb" -o \
        -name "*.ico" -o -name "*.lnk" -o -name "*.msg" -o -name "*.zip" \
    \) -exec rm -f {} \;

    # Move splash file if it exists
    if [ -f "$DATADIR/splash.png" ]; then
        mv "$DATADIR/splash.png" "$GAMEDIR/splash.png"
    fi

    # Check if we're using a prepatched game
    if unzip -l "$DATAFILE" "assets/*" | grep -q "assets/.*\.dat"; then
        echo "Prepatched game detected."
        PREPATCH=1
        unzip_audiogroups || { cleanup; return 1; }
    fi
}

unzip_audiogroups() {
    echo "Unzipping ${DATAFILE}..."
    mkdir -p assets
    "$controlfolder/7zzs.${DEVICE_ARCH}" e -y "$DATAFILE" "assets/*.dat" -o"$DATADIR"
    if [ $? -eq 0 ]; then
        echo "Unzipped successfully to $DATADIR."
    else
        emit_fail_msg "Failed to unzip file."
        return 1
    fi
}

# Toggle GeneralInfo flags via envars - see https://github.com/UnderminersTeam/UndertaleModTool/blob/master/UndertaleModLib/Models/UndertaleGeneralInfo.cs for options
set_flags() {
    export SET_FLAGS="Fullscreen"
    export CLEAR_FLAGS="Scale"
    dotnet "$TOOLKIT/utmt-cli/UndertaleModCli.dll" \
        load "$DATADIR/data.win" \
        -s "$GAMEDIR/tools/toggleflags.csx" \
        -o "$DATADIR/data2.win"
        
    if [ $? -ne 0 ]; then
        emit_fail_msg "Failed to toggle info flags."
        return 1
    else
        echo "Successfully toggled info flags."
        rm -f "$DATADIR/data.win"
        mv "$DATADIR/data2.win" "$DATADIR/data.win"
        if [ -n "$TMPDIR" ] && [ -d "$TMPDIR" ]; then
            rm -rf "$TMPDIR"/*
        fi
    fi
}

# Compress audio files inside datafile and audiogroups
compress_audio() {
    # Purge cache before operations
    rm -rf "$TMPDIR/"*

    # Run the compression tool
    if [ "$PREPATCH" != 1 ]; then
        echo "Running GMTools on data and audiogroups."
        $PYTHON "$TOOLKIT/gmtools/gmKtool.py" -vv -m 1000 -r -b 64 -d "$TMPDIR" "$DATADIR/data.win"
    else
        echo "Running GMTools on data file only."
        $PYTHON "$TOOLKIT/gmtools/gmKtool.py" -vv -O 0 -m 1000 -b 64 -r -d "$TMPDIR" "$DATADIR/data.win"
    fi

    if [ $? -eq 0 ]; then
        echo "Compression completed successfully."
        mv "$TMPDIR/"* "$DATADIR"
        echo "Moved compressed files to $DATADIR."
        rm -rf "$TMPDIR"
        echo "Temporary directory $TMPDIR removed."
        echo "Audio compression applied successfully."
    else
        # Failure
        emit_fail_msg "Audio compression failed."
        rmdir "$TMPDIR"
        return 1
    fi
}

# Zip it all into the .port file
zip_archive() {
    [ -f "$DATADIR/data.win" ] && mv "$DATADIR/data.win" "$DATADIR/game.droid"
    if "$controlfolder/7zzs.${DEVICE_ARCH}" a -tzip -aoa -mx=0 "$GAMEDIR/$DATAFILE" "$DATADIR"; then
        rm -rf "$DATADIR"/*
    else
        emit_fail_msg "Failed to create $DATAFILE."
        return 1
    fi
}

# Cleanup function
cleanup() {
    rm -rf "$TMPDIR"
    $ESUDO umount "$DOTNETDIR" 2>/dev/null || true
    $ESUDO umount "$TOOLKIT" 2>/dev/null || true
}

process_game() {
    echo "Preparing system..."
    prepare_system || { cleanup; return 1; }
    echo "Preparing game..."
    prepare_files || { cleanup; return 1; }
    echo "Compressing audio..."
    compress_audio || { cleanup; return 1; }
    echo "Toggling GeneralInfo flags..."
    set_flags || { cleanup; return 1; }
    echo "Finishing up..."
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi

# Always run cleanup at the end
cleanup
