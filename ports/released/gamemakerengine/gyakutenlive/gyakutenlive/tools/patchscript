#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1
echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/assets"
export DATAFILE="gyakutenlive.port"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    # Test for commands: python, zip
    PYTHON=$(command -v python3)
    if [ -z "$PYTHON" ]; then
        echo "Missing Python!"
        return 1
    fi

    ZIP=$(command -v zip)
    if [ -z "$ZIP" ]; then
        echo "Missing zip!"
        return 1
    fi

    # Mount the GMToolkit runtime
    TOOLKIT="$HOME/gmtoolkit"
    RUNTIME="$controlfolder/libs/gmtoolkit.squashfs"
    if [ -f "$RUNTIME" ]; then
        $ESUDO mkdir -p "$TOOLKIT"
        $ESUDO umount "$TOOLKIT" 2>/dev/null || true
        $ESUDO mount "$RUNTIME" "$TOOLKIT"
    else
        echo "This port requires the GMToolkit runtime. Please download it."
        return 1
    fi

    # Mount the dotnet runtime
    DOTNETDIR="$HOME/mono"
    DOTNETFILE="$controlfolder/libs/dotnet-8.0.12.squashfs"
    if [ -f "$DOTNETFILE" ]; then
        $ESUDO mkdir -p "$DOTNETDIR"
        $ESUDO umount "$DOTNETDIR" 2>/dev/null || true
        $ESUDO mount "$DOTNETFILE" "$DOTNETDIR"
    else
        echo "This port requires the Dotnet runtime. Please download it."
        return 1
    fi

    # Attempt to get SAVEDIR from gmloader.json using jq
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
    else
        SAVEDIR="$GAMEDIR/saves"
    fi

    # Exports
    export PYTHON
    export ZIP
    export SAVEDIR
    export PATH="$DOTNETDIR:$TOOLKIT/gmtools:$TOOLKIT/utmt-cli:$PATH"
    export LD_LIBRARY_PATH="$TOOLKIT/libs:$LD_LIBRARY_PATH"

    # These exports help dotnet save memory and hopefully eliminate oomkill issues during patching
    export DOTNET_gcServer=0
    export DOTNET_gcLatencyLevel=SustainedLowLatency
    export DOTNET_GCHighMemPercent=50
}

# Cleanup function
cleanup() {
    rm -rf "$TMPDIR"
    $ESUDO umount "$DOTNETDIR" 2>/dev/null || true
    $ESUDO umount "$TOOLKIT" 2>/dev/null || true
}

cd "$GAMEDIR"

prepare_files() {
    mkdir -p "$SAVEDIR"

    # Delete excess files and folders
    find "$DATADIR" \( -type f \( -name "*.exe" -o -name "*.dll" -o -name "*.webm" \) -o \
                       -type d \( -name "\$PLUGINSDIR" -o -name "\$TEMP" \) \) -exec rm -rf {} +
}

apply_xdelta() {
    # Check if the data.win file exists and apply xdelta
    if [ -f "$DATADIR/data.win" ]; then
        output=$($controlfolder/xdelta3 -d -s "$DATADIR/data.win" -f "$GAMEDIR/tools/gyakuten-live.xdelta" "$DATADIR/data2.win" 2>&1)
        if [ $? -eq 0 ]; then
            echo "Patch applied successfully"
            echo "$output"
            rm -rf "$DATADIR/data.win"
            mv "$DATADIR/data2.win" "$DATADIR/data.win"
        else
            echo "Failed to apply patch"
            echo "$output"
            return 1
        fi
    else
        echo "No data.win file found to patch!"
        return 1
    fi
}

# Externalize game textures with compression
dump_textures() {
    # Purge cache before operations
    if [ -n "$TMPDIR" ] && [ -d "$TMPDIR" ]; then
        rm -rf "$TMPDIR"/*
    fi

    # Begin texture operations
    if ! dotnet "$TOOLKIT/utmt-cli/UndertaleModCli.dll" \
        dump "$DATADIR/data.win" \
        -e "$DATADIR/textures" "$DATADIR/data2.win"; then
        echo "[DOTNET]: Texture dumping failed to apply."
        return 1
    fi

    # Cleanup & move textures
    rm -f "$DATADIR/data.win" && mv "$DATADIR/data2.win" "$DATADIR/data.win"
    [ -d "$SAVEDIR/textures" ] && rm -rf "$SAVEDIR/textures"
    mv "$DATADIR/textures" "$SAVEDIR/textures"

    # Final cleanup
    if [ -n "$TMPDIR" ] && [ -d "$TMPDIR" ]; then
        rm -rf "$TMPDIR"/*
    fi
}

compress_audio() {
    # Do audio compression
    if $PYTHON "$TOOLKIT/gmtools/gmKtool.py" -vv -m 1000 -r -b 64 -d "$TMPDIR" "$DATADIR/data.win"; then
        mv "$TMPDIR/"* "$DATADIR" && rmdir "$TMPDIR"
        echo "Audio compression applied successfully."
    else
        # Failure
        echo "Audio compression failed."
        rmdir "$TMPDIR"
        return 1
    fi
}

zip_archive() {
    [ -f "$DATADIR/data.win" ] && mv "$DATADIR/data.win" "$DATADIR/game.droid"
    $ZIP -r -0 "$DATAFILE" ./assets/
    echo "Zipped contents to $DATAFILE"
    rm -rf "$DATADIR/"*
}

process_game() {
    echo "Preparing system..."
    prepare_system || { cleanup; return 1; }

    echo "Preparing game..."
    prepare_files || { cleanup; return 1; }

    echo "Applying patch..."
    apply_xdelta || { cleanup; return 1; }

    echo "Compressing audio..."
    compress_audio || { cleanup; return 1; }

    echo "Externalizing textures..."
    dump_textures || { cleanup; return 1; }

    sleep 1
    echo "Finishing up..."
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi

# Always run cleanup at the end
cleanup
