#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
rm -f "$GAMEDIR/$LOGERR"
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
}

# Default failure-dialog message; overridden at specific failure points below.
emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/assets"
export DATAFILE="sonictt16b.port"
export APKFILE="sonic-triple-trouble-16-bit-v1-2-8.apk"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    # Test for commands: python, zip
    PYTHON=$(which python3)
    if [ -z "$PYTHON" ]; then
        emit_fail_msg "Missing Python!"
        return 1
    fi
    
    # Mount the GMToolkit runtime
    TOOLKIT="$HOME/gmtoolkit"
    RUNTIME="$controlfolder/libs/gmtoolkit.squashfs"
    if [ -f "$RUNTIME" ]; then
        $ESUDO mkdir -p "$TOOLKIT"
        $ESUDO umount "$TOOLKIT" 2>/dev/null || true
        $ESUDO mount "$RUNTIME" "$TOOLKIT"
    else
        emit_fail_msg "This port requires the GMToolkit runtime. Please download it."
        return 1
    fi

    # Mount the dotnet runtime
    DOTNETDIR="$HOME/mono"
    DOTNETFILE="$controlfolder/libs/dotnet-8.0.12.squashfs"
    if [ -f "$DOTNETFILE" ]; then
        $ESUDO mkdir -p "$DOTNETDIR"
        $ESUDO umount "$DOTNETDIR" 2>/dev/null || true
        $ESUDO mount "$DOTNETFILE" "$DOTNETDIR"
    else
        emit_fail_msg "This port requires the Dotnet runtime. Please download it."
        return 1
    fi

    # Attempt to get SAVEDIR from gmloader.json using jq
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
    else
        SAVEDIR="$GAMEDIR/saves"
    fi
    
    # Exports
    export PYTHON
    export SAVEDIR
    export PATH="$DOTNETDIR:$TOOLKIT/gmtools:$TOOLKIT/utmt-cli:$PATH"
    export LD_LIBRARY_PATH="/usr/lib:$TOOLKIT/libs:$LD_LIBRARY_PATH"

    # These exports help dotnet save memory and hopefully eliminate oomkill issues during patching
    export DOTNET_gcServer=0
    export DOTNET_gcLatencyLevel=SustainedLowLatency
    export DOTNET_GCHighMemPercent=50
}

unzip_apk() {
    if [ -f "$GAMEDIR/$APKFILE" ]; then
        echo "Extracting apk file..."
        mkdir -p "$TMPDIR"
        if "$controlfolder/7zzs.${DEVICE_ARCH}" x -y "$GAMEDIR/$APKFILE" -o"$TMPDIR"; then
            if [ -d "$TMPDIR/lib" ]; then
                "$controlfolder/7zzs.${DEVICE_ARCH}" a -tzip -aoa -mx=0 \
                    "$GAMEDIR/$DATAFILE" "$TMPDIR/lib" || {
                    emit_fail_msg "Failed lib packaging"
                    return 1
                }
            else
                emit_fail_msg "lib directory not found in APK"
                find "$TMPDIR" -maxdepth 2 -type d
                return 1
            fi

            if [ -d "$TMPDIR/assets" ]; then
                mkdir -p "$GAMEDIR/assets"
                cp -R "$TMPDIR/assets/." "$GAMEDIR/assets/"
            else
                emit_fail_msg "assets missing in APK"
                find "$TMPDIR" -maxdepth 2 -type d
                return 1
            fi

            rm -rf "$TMPDIR" "$GAMEDIR/$APKFILE"

            rm -f "$DATADIR"/*.exe "$DATADIR"/*.txt "$DATADIR"/.gitkeep "$DATADIR"/manual*.png "$DATADIR"/portrait_splash.png

        else
            emit_fail_msg "Error unzipping apk!"
            return 1
        fi
    else
        emit_fail_msg "Did not find $GAMEDIR/$APKFILE!"
        return 1
    fi
}

apply_xdelta() {
    # Check if the game.droid file exists and apply xdelta
    if [ -f "$DATADIR/game.droid" ]; then
        output=$($controlfolder/xdelta3 -d -s "$DATADIR/game.droid" -f "$GAMEDIR/tools/patches/sonictt16b.xdelta" "$DATADIR/game2.droid" 2>&1)
        if [ $? -eq 0 ]; then
            echo "Patch applied successfully"
            echo "$output"
            rm "$DATADIR/game.droid" && mv "$DATADIR/game2.droid" "$DATADIR/game.droid"
        else
            emit_fail_msg "Failed to apply patch"
            echo "$output"
            return 1
        fi
    else
        echo "No game.droid file found to patch!"
    fi
}

compress_audio() {
    # Do audio compression
    if $PYTHON "$TOOLKIT/gmtools/gmKtool.py" -vv -m 1000 -r -b 64 -d "$TMPDIR" "$DATADIR/game.droid"; then
        mv "$TMPDIR/"* "$DATADIR" && rmdir "$TMPDIR"
        echo "Audio compression applied successfully."
    else
        # Failure
        emit_fail_msg "Audio compression failed."
        rmdir "$TMPDIR"
        return 1
    fi
}

# Zip it all into the .port file
zip_archive() {
    if "$controlfolder/7zzs.${DEVICE_ARCH}" a -tzip -aoa -mx=0 "$GAMEDIR/$DATAFILE" "$DATADIR"; then
        rm -rf "$DATADIR"/*
    else
        emit_fail_msg "Failed to create $DATAFILE."
        return 1
    fi
}

cleanup() {
    rm -rf "$TMPDIR"
    $ESUDO umount "$DOTNETDIR" 2>/dev/null || true
    $ESUDO umount "$TOOLKIT" 2>/dev/null || true
}

process_game() {
    prepare_system || { cleanup; return 1; }
    echo "Looking for apk file..."
    unzip_apk || { cleanup; return 1; }
    echo "Applying patch..."
    apply_xdelta || { cleanup; return 1; }
    echo "Compressing audio..."
    compress_audio || { cleanup; return 1; }
    echo "Finishing up..."
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi

cleanup
