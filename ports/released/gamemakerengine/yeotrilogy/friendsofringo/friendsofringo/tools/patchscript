#!/bin/bash
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

rm -f "$GAMEDIR/$LOGERR"
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
}

# Default failure-dialog message; overridden at specific failure points below.
emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
echo "GAMEDIR is set to: $GAMEDIR"

export DATADIR="$GAMEDIR/assets"
export DATAFILE="ringo.port"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    # Test for python
    PYTHON=$(command -v python3)
    if [ -z "$PYTHON" ]; then
        emit_fail_msg "Missing Python!"
        return 1
    fi

    ZIP=$(command -v zip)
    if [ -z "$ZIP" ]; then
        emit_fail_msg "Missing zip!"
        return 1
    fi

    # Mount the GMToolkit runtime
    TOOLKIT="$HOME/gmtoolkit"
    RUNTIME="$controlfolder/libs/gmtoolkit.squashfs"
    if [ -f "$RUNTIME" ]; then
        $ESUDO mkdir -p "$TOOLKIT"
        $ESUDO umount "$TOOLKIT" 2>/dev/null || true
        $ESUDO mount "$RUNTIME" "$TOOLKIT"
    else
        emit_fail_msg "This port requires the GMToolkit runtime. Please download it."
        sleep 2
        return 1
    fi

    # Mount the dotnet runtime
    DOTNETDIR="$HOME/mono"
    DOTNETFILE="$controlfolder/libs/dotnet-8.0.12.squashfs"
    if [ -f "$DOTNETFILE" ]; then
        $ESUDO mkdir -p "$DOTNETDIR"
        $ESUDO umount "$DOTNETDIR" 2>/dev/null || true
        $ESUDO mount "$DOTNETFILE" "$DOTNETDIR"
    else
        emit_fail_msg "This port requires the Dotnet runtime. Please download it."
        sleep 2
        return 1
    fi

    # Attempt to get SAVEDIR from gmloader.json using jq
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
    else
        SAVEDIR="$GAMEDIR/saves"
    fi

    # Exports
    export PYTHON
    export SAVEDIR
    export PATH="$DOTNETDIR:$TOOLKIT/gmtools:$TOOLKIT/utmt-cli:$PATH"
    export LD_LIBRARY_PATH="$TOOLKIT/libs:$LD_LIBRARY_PATH"

    # These exports help dotnet save memory and hopefully eliminate oomkill issues during patching
    export DOTNET_gcServer=0
    export DOTNET_gcLatencyLevel=SustainedLowLatency
    export DOTNET_GCHighMemPercent=50
}

cleanup() {
    rm -rf "$TMPDIR"
    $ESUDO umount "$DOTNETDIR" 2>/dev/null || true
    $ESUDO umount "$TOOLKIT" 2>/dev/null || true
}

cd "$GAMEDIR"

prepare_files() {
    mkdir -p "$SAVEDIR"

    # Delete excess files
    find "$DATADIR" -type f \( \
        -name "*.gitkeep" -o -name "*.exe" -o -name "*.dll" -o -name "*.hashdb" -o \
        -name "*.ico" -o -name "*.lnk" -o -name "*.msg" -o -name "*.zip" \
    \) -exec rm -f {} \;

    # Move splash file if it exists
    if [ -f "$DATADIR/splash.png" ]; then
        mv "$DATADIR/splash.png" "$GAMEDIR/splash.png"
    fi
}

# Dump game code entries from data.win
dump_code() {
    # Purge cache before operations
    rm -rf "$TMPDIR/"*

    # Specify which code entries to extract
    CODE_ENTRIES=(
        "gml_GlobalScript_screen_init"
    )

    CODEARGS=""
    for entry in "${CODE_ENTRIES[@]}"; do
        CODEARGS="$CODEARGS --code $entry"
    done

    echo "Dumping GML scripts: ${CODE_ENTRIES[*]}"

    dotnet "$TOOLKIT/utmt-cli/UndertaleModCli.dll" \
        dump "$DATADIR/data.win" \
        -o "$TMPDIR" \
        $CODEARGS

    if [ $? -ne 0 ]; then
        emit_fail_msg "Failed to dump GML scripts."
        return 1
    fi

    echo "GML scripts dumped to $TMPDIR"
}

modify_code() {
    # Modify the extracted gml
    $PYTHON "$GAMEDIR/tools/mod.py" "$TMPDIR/CodeEntries"
    if [ $? -ne 0 ]; then
        emit_fail_msg "Failed to modify GML scripts."
        return 1
    fi
}

# Replace game code entries for data.win
replace_code() {
    # Build --code args from all gml files
    CODEARGS=""
    for file in "$TMPDIR/CodeEntries/"*.gml; do
        [ -f "$file" ] || continue
        entry=$(basename "$file" .gml)
        echo "Will replace gml script: $file"
        CODEARGS="$CODEARGS --code $entry=$file"
    done

    # Begin replace operations
    dotnet "$TOOLKIT/utmt-cli/UndertaleModCli.dll" \
        replace "$DATADIR/data.win" \
        -o "$DATADIR/data2.win" \
        $CODEARGS

    if [ $? -ne 0 ]; then
        emit_fail_msg "Failed to replace gml scripts."
        return 1
    else
        echo "Successfully replaced gml scripts."
        rm -f "$DATADIR/data.win"
        mv "$DATADIR/data2.win" "$DATADIR/data.win"
        if [ -n "$TMPDIR" ] && [ -d "$TMPDIR" ]; then
            rm -rf "$TMPDIR"/*
        fi
    fi
}

# Toggle GeneralInfo flags via envars - see https://github.com/UnderminersTeam/UndertaleModTool/blob/master/UndertaleModLib/Models/UndertaleGeneralInfo.cs for options
set_flags() {
    export SET_FLAGS="Fullscreen"
    export CLEAR_FLAGS="Scale"
    dotnet "$TOOLKIT/utmt-cli/UndertaleModCli.dll" \
        load "$DATADIR/data.win" \
        -s "$GAMEDIR/tools/toggleflags.csx" \
        -o "$DATADIR/data2.win"

    if [ $? -ne 0 ]; then
        emit_fail_msg "Failed to toggle info flags."
        return 1
    else
        echo "Successfully toggled info flags."
        rm -f "$DATADIR/data.win"
        mv "$DATADIR/data2.win" "$DATADIR/data.win"
        if [ -n "$TMPDIR" ] && [ -d "$TMPDIR" ]; then
            rm -rf "$TMPDIR"/*
        fi
    fi
}

# Externalize game textures with compression
dump_textures() {
    # Purge cache before operations
    rm -rf "$TMPDIR/"*

    # Begin texture operations
    dotnet "$TOOLKIT/utmt-cli/UndertaleModCli.dll" \
        dump "$DATADIR/data.win" \
        -e "$DATADIR/textures" "$DATADIR/data2.win"

    if [ $? -ne 0 ]; then
        emit_fail_msg "[DOTNET]: Texture dumping failed to apply."
        return 1
    else
        rm -f "$DATADIR/data.win" && mv "$DATADIR/data2.win" "$DATADIR/data.win"
        mv "$DATADIR/textures" "$SAVEDIR/textures"
        if [ -n "$TMPDIR" ] && [ -d "$TMPDIR" ]; then
            rm -rf "$TMPDIR"/*
        fi
    fi
}

compress_audio() {
    # Do audio compression
    if $PYTHON "$TOOLKIT/gmtools/gmKtool.py" -vv -m 1000 -r -b 64 -d "$TMPDIR" "$DATADIR/data.win"; then
        mv "$TMPDIR/"* "$DATADIR" && rmdir "$TMPDIR"
        echo "Audio compression applied successfully."
    else
        # Failure
        emit_fail_msg "Audio compression failed."
        rmdir "$TMPDIR"
        return 1
    fi
}

zip_archive() {
        [ -f "$DATADIR/data.win" ] && mv "$DATADIR/data.win" "$DATADIR/game.droid"
        zip -r -0 "$DATAFILE" ./assets/
        echo "Zipped contents to $DATAFILE"
        rm -rf "$DATADIR/"*
}

process_game() {
    prepare_system || { cleanup; return 1; }
    echo "Preparing game..."
    prepare_files || { cleanup; return 1; }
    echo "Compressing audio..."
    compress_audio || { cleanup; return 1; }
    echo "Setting info flags..."
    set_flags || { cleanup; return 1; }
    echo "Dumping game code..."
    dump_code || { cleanup; return 1; }
    echo "Modifying gml scripts..."
    modify_code || { cleanup; return 1; }
    echo "Repacking gml scripts..."
    replace_code || { cleanup; return 1; }
    echo "Externalizing textures..."
    dump_textures || { cleanup; return 1; }
    echo "Finishing up..."
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi
cleanup
