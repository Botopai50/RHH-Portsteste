#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
rm -f "$GAMEDIR/$LOGERR"
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
}

# Default failure-dialog message; overridden at specific failure points below.
emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/assets"
export DATAFILE="dtr.port"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    # Test for python
    PYTHON=$(command -v python3)
    if [ -z "$PYTHON" ]; then
        emit_fail_msg "Missing Python!"
        return 1
    fi

    # Test for zip
    ZIP=$(which zip)
    if [ -z "$ZIP" ]; then
        emit_fail_msg "Missing zip!"
        return 1
    fi

    # Mount the GMToolkit runtime
    TOOLKIT="$HOME/gmtoolkit"
    RUNTIME="$controlfolder/libs/gmtoolkit.squashfs"
    if [ -f "$RUNTIME" ]; then
        $ESUDO mkdir -p "$TOOLKIT"
        $ESUDO umount "$TOOLKIT" 2>/dev/null || true
        $ESUDO mount "$RUNTIME" "$TOOLKIT"
    else
        emit_fail_msg "This port requires the GMToolkit runtime. Please download it."
        sleep 2
        return 1
    fi

    # Attempt to get SAVEDIR from gmloader.json using jq
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
    else
        SAVEDIR="$GAMEDIR/saves"
    fi

    # Path and library exports
    export PATH="$TOOLKIT/gmtools:$TOOLKIT/utmt-cli:$PATH"
    export LD_LIBRARY_PATH="/usr/lib:$TOOLKIT/libs:$LD_LIBRARY_PATH"

    # Port-specific: TOOLDIR for xdelta patches
    export TOOLDIR="$GAMEDIR/tools"
}

prepare_files() {
    # Unzip the executable if it exists
    echo "Unpacking the game..."
    ./tools/7za x "$DATADIR/DigitalTamers ReBorn - v2.2.2 - (PC).exe" -o"$DATADIR" -y
    rm -f "$DATADIR"/*.exe "$DATADIR"/*.dll "$DATADIR/.gitkeep"
    [ -f "$DATADIR/splash.png" ] && mv "$DATADIR/splash.png" .
    echo "Removed unnecessary files"
    sleep 1
}

unzip_patch() {
    echo "Unzipping the patch file..."
    if [ -f "./tools/patches/dtr.zip.001" ]; then
        ./tools/7za x ./tools/patches/dtr.zip.001 -o./tools/patches
        if [ $? -eq 0 ]; then
            echo "Patch file successfully extracted."
            rm ./tools/patches/dtr.zip.*
        else
            emit_fail_msg "Failed to extract multi-part archive."
            return 1
        fi
    else
        emit_fail_msg "Patch archive not found!"
        return 1
    fi
}

apply_xdelta() {
    echo "Applying xdelta patch"
    # Check if the data.win file exists and apply xdelta
    if [ -f "$DATADIR/data.win" ] && [ -f "$TOOLDIR/patches/dtr.xdelta" ]; then
        output=$($controlfolder/xdelta3 -d -s "$DATADIR/data.win" -f "$TOOLDIR/patches/dtr.xdelta" "$DATADIR/data.patched" 2>&1)
        if [ $? -eq 0 ]; then
            echo "Patch applied successfully"
            echo "$output"
            mv "$DATADIR/data.patched" "$DATADIR/data.win"
            sleep 1
        else
            emit_fail_msg "Failed to apply patch"
            echo "$output"
            mv $LOGFILE $LOGERR
            sleep 1
            return 1
        fi
    else
        echo "No data.win file found to patch or no patch file provided."
        sleep 1
    fi
}

compress_audio() {
    if $PYTHON "$TOOLKIT/gmtools/gmKtool.py" -vv -m 1000 -r -b 64 -d "$TMPDIR" "$DATADIR/data.win"; then
        mv "$TMPDIR/"* "$DATADIR" && rmdir "$TMPDIR"
        echo "Audio compression applied successfully."
    else
        # Failure
        emit_fail_msg "Audio compression failed."
        rmdir "$TMPDIR"
        return 1
    fi
}

zip_archive() {
        echo "Finishing up..."
        [ -f "$DATADIR/data.win" ] && mv "$DATADIR/data.win" "$DATADIR/game.droid"
        zip -r -0 $DATAFILE ./assets/
        mkdir -p saves
        rm -rf assets
        sleep 1
}

cleanup() {
    rm -rf "$TMPDIR"
    $ESUDO umount "$TOOLKIT" 2>/dev/null || true
}

process_game() {
    echo "Preparing game..."
    prepare_system || { cleanup; return 1; }
    prepare_files || { cleanup; return 1; }
    unzip_patch || { cleanup; return 1; }
    echo "Applying xdelta patch..."
    apply_xdelta || { cleanup; return 1; }
    echo "Compressing audio..."
    compress_audio || { cleanup; return 1; }
    sleep 1
    echo "Finishing up..."
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
fi

cleanup
