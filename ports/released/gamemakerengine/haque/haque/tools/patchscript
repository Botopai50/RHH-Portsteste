#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
rm -f "$GAMEDIR/$LOGERR"
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}

echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/assets"
export DATAFILE="haque.port"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    # Test for python
    PYTHON=$(command -v python3)
    if [ -z "$PYTHON" ]; then
        emit_fail_msg "Missing Python!"
        return 1
    fi

    # Test for zip
    ZIP=$(which zip)
    if [ -z "$ZIP" ]; then
        emit_fail_msg "Missing zip!"
        return 1
    fi

    # Mount the GMToolkit runtime
    TOOLKIT="$HOME/gmtoolkit"
    RUNTIME="$controlfolder/libs/gmtoolkit.squashfs"
    if [ -f "$RUNTIME" ]; then
        $ESUDO mkdir -p "$TOOLKIT"
        $ESUDO umount "$TOOLKIT" 2>/dev/null || true
        $ESUDO mount "$RUNTIME" "$TOOLKIT"
    else
        emit_fail_msg "This port requires the GMToolkit runtime. Please download it."
        sleep 2
        return 1
    fi

    # Attempt to get SAVEDIR from gmloader.json using jq
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
    else
        SAVEDIR="$GAMEDIR/saves"
    fi

    # Path and library exports
    export PATH="$TOOLKIT/gmtools:$TOOLKIT/utmt-cli:$PATH"
    export LD_LIBRARY_PATH="/usr/lib:$TOOLKIT/libs:$LD_LIBRARY_PATH"
}

prepare_files() {
    # Delete unnecessary files
    rm -rf $DATADIR/*.so $DATADIR/*.exe $DATADIR/*.dll $DATADIR/*.icns \
           $DATADIR/.gitkeep $DATADIR/gamedat $DATADIR/runner $DATADIR/English.lproj
    echo "Removed unnecessary files"
    if [ -f "$DATADIR/game.unx" ]; then
        mv "$DATADIR/game.unx" "$DATADIR/data.win"
    elif [ -f "$DATADIR/game.ios" ]; then
        mv "$DATADIR/game.ios" "$DATADIR/data.win"
    fi

    # Edit options.ini
    if [ -f "$DATADIR/options.ini" ]; then
        if grep -q '^CreateTexturesOnDemand=' "$DATADIR/options.ini"; then
            sed -i 's/^CreateTexturesOnDemand=.*/CreateTexturesOnDemand=1/' "$DATADIR/options.ini"
        else
            echo 'CreateTexturesOnDemand=1' >> "$DATADIR/options.ini"
        fi
    else
        emit_fail_msg "Error: options.ini missing!"
        mv "$PATCHLOG" "$PATCHERR"
        return 1
    fi
    sleep 1

    if [ ! -d "$DATADIR/Haque_Text" ]; then
        # Try to locate the Haque_Text.zip file (case-insensitive)
        file=$(find "$DATADIR" -maxdepth 1 -iname "Haque_Text.zip" | head -n 1)

        if [ -n "$file" ]; then
            unzip "$file" -d "$DATADIR"
            find "$DATADIR/Haque_Text/" -type f -exec dos2unix -u {} \;
            rm -f "$file"
        else
            emit_fail_msg "Couldn't find Haque_Text.zip! Game will not run!"
            sleep 2
            return 1
        fi
    else
        find "$DATADIR/Haque_Text/" -type f -exec dos2unix -u {} \;
    fi
}

compress_audio() {
    if $PYTHON "$TOOLKIT/gmtools/gmKtool.py" -vv -m 1000 -r -b 64 -d "$TMPDIR" "$DATADIR/data.win"; then
        mv "$TMPDIR/"* "$DATADIR" && rmdir "$TMPDIR"
        echo "Audio compression applied successfully."
    else
        # Failure
        emit_fail_msg "Audio compression failed."
        rmdir "$TMPDIR"
        return 1
    fi
}

zip_archive() {
        echo "Finishing up..."
        [ -f "$DATADIR/data.win" ] && mv "$DATADIR/data.win" "$DATADIR/game.droid"
        zip -r -0 $DATAFILE ./assets/
        mkdir -p saves
        rm -rf $DATADIR/*
        sleep 1
}

cleanup() {
    rm -rf "$TMPDIR"
    $ESUDO umount "$TOOLKIT" 2>/dev/null || true
}

process_game() {
    prepare_system || { cleanup; return 1; }
    prepare_files || { cleanup; return 1; }
    compress_audio || { cleanup; return 1; }
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi

cleanup
