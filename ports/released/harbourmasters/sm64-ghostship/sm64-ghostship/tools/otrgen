#!/bin/bash

# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="$GAMEDIR/tools/otrlog.txt"
# The game (RunExtract) checks for $GAMEDIR/assets on every launch, and torch's
# -s srcdir must hold config.yml + assets/ together (config.yml's paths are
# relative). So assets/ extracts to $GAMEDIR (not tools/) and is kept there.
ASSETS_ZIP="$GAMEDIR/tools/assets.zip"
ASSETS_DIR="$GAMEDIR"
SEVENZIP="$controlfolder/7zzs.${DEVICE_ARCH}"

# Redirect output and error to the log file
rm -rf $LOGFILE
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
exec > >(tee -a "$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}

echo "GAMEDIR is set to: $GAMEDIR"

# Check if we need to unzip the assets archive
unzip_assets() {
    if [ ! -x "$SEVENZIP" ]; then
        emit_fail_msg "7zzs binary not found at $SEVENZIP"
        return 1
    fi

    if [ -f "$ASSETS_ZIP" ]; then
        echo "Extracting assets.zip..."
        if "$SEVENZIP" x -y "$ASSETS_ZIP" -o"$ASSETS_DIR" >/dev/null; then
            rm -f "$ASSETS_ZIP"
        else
            emit_fail_msg "[OTRGEN] Unable to extract assets.zip."
            return 1
        fi
    fi
}

# Function handle the ROM file.
process_rom() {
    cd "$GAMEDIR"
    local input_file="$1"
    if [ ! -f "baseroms/$input_file" ]; then
        emit_fail_msg "[OTRGEN] Error: File $input_file not found!"
        exit 1
    fi

    # torch's -s srcdir needs config.yml beside assets/. config.yml ships in
    # tools/, so place a copy at $GAMEDIR (alongside the extracted assets/).
    cp -f "$GAMEDIR/tools/config.yml" "$GAMEDIR/config.yml"

    echo "Extracting data from $input_file..."
    ver=$("$SEVENZIP" e -so "$GAMEDIR/ghostship.o2r" portVersion 2>/dev/null \
          | dd bs=1 skip=1 count=6 2>/dev/null | od -An -t u2 | awk '{print $1"."$2"."$3}')
    if [ -z "$ver" ]; then
        emit_fail_msg "[OTRGEN] Couldn't read version from ghostship.o2r."
        exit 1
    fi
    # -s $GAMEDIR: config.yml + assets/ live here; torch writes sm64.o2r to cwd.
    if ./tools/torch o2r "baseroms/$input_file" -s "$GAMEDIR" -u "$ver"; then
        echo "[OTRGEN] Extraction complete. O2R generated."
    else
        emit_fail_msg "[OTRGEN] Error: Extraction failed for $input_file."
        exit 1
    fi
}

# Function to convert N64 ROM to Z64 format
convert_n64() {
    local rom_file="$1"
    local output_file="$GAMEDIR/baseroms/rom.z64"

    if [[ ! -f "$rom_file" ]]; then
        emit_fail_msg "Error: File $rom_file not found!"
        return 1
    fi

    # Read the first 4 bytes of the file
    word=$(hexdump -n 4 -e '4/1 "%02x"' "$rom_file")

    case "$word" in
        "37804012")
            echo "[OTRGEN] Detected Big Endian format. Converting to Z64..."
            dd if="$rom_file" of="$output_file" conv=swab 2>/dev/null || return 1
            ;;
        "40123780")
            echo "[OTRGEN] Detected Little Endian format. Converting to Z64..."
            dd if="$rom_file" of="$output_file" conv=swab,notrunc bs=4 2>/dev/null || return 1
            ;;
        "80371240")
            echo "[OTRGEN] ROM already uses Z64 byte ordering. Copying as-is."
            cp "$rom_file" "$output_file" || return 1
            ;;
        *)
            emit_fail_msg "Error: Format identification failed for $rom_file."
            return 1
            ;;
    esac

    echo "[OTRGEN] Conversion complete. Saved as $output_file."
}

# Main logic
rom_file=$(find "$GAMEDIR/baseroms" -maxdepth 1 \( -name "*.z64" -o -name "*.n64" \) -print -quit)

# Test if regenerating o2r. assets/ now persists unpacked at $GAMEDIR, so a
# missing assets.zip is normal after first run — only fail if BOTH are gone.
if [ -n "$REGEN" ] && [ ! -f "$ASSETS_ZIP" ] && [ ! -d "$GAMEDIR/assets" ]; then
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
    echo "Patching process failed!"
    exit 1
fi

if [ -z "$rom_file" ]; then
    emit_fail_msg "[OTRGEN] No ROM file found in baseroms!"
    exit 1
fi

if [ -f "$ASSETS_ZIP" ]; then
    unzip_assets
fi

echo "Processing $rom_file..."

case "$rom_file" in
    *.n64)
        convert_n64 "$rom_file" || { echo "Patching process failed!"; exit 1; }
        rm -f "$rom_file"
        process_rom "rom.z64"  || { echo "Patching process failed!"; exit 1; }
        ;;
    *.z64)
        process_rom "$(basename "$rom_file")"  || { echo "Patching process failed!"; exit 1; }
        ;;
esac

# Cleanup
echo "Patching process complete!"
