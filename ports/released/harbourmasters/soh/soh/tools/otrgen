#!/bin/bash

# Set up vars and logging
GAMEDIR="$PWD"
BASEROMS_DIR="$GAMEDIR/baseroms"
ARGS=""
i=1
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/tools/otrlog.txt" && exec > >(tee "$GAMEDIR/tools/otrlog.txt") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}


# Exports
export LD_LIBRARY_PATH="$GAMEDIR/libs:$LD_LIBRARY_PATH"

unzip_assets() {
    # Define 7zzs binary
    SEVENZIP="$controlfolder/7zzs.${DEVICE_ARCH}"
    if [ ! -x "$SEVENZIP" ]; then
        emit_fail_msg "7zzs binary not found at $SEVENZIP"
        return 1
    fi

    EXTRACTOR_ZIP="$GAMEDIR/assets/extractor.zip"
    EXTRACTOR_DIR="$GAMEDIR/assets"

    if [ -f "$EXTRACTOR_ZIP" ]; then
        echo "Extracting extractor.zip..."
        if "$SEVENZIP" x -y "$EXTRACTOR_ZIP" -o"$EXTRACTOR_DIR" >/dev/null; then
            chmod +x "$EXTRACTOR_DIR/extractor/ZAPD.out"
            rm -f "$EXTRACTOR_ZIP"
        else
            emit_fail_msg "Error: Extraction failed"
            return 1
        fi
    fi
}

process_roms() {
    # Collect ROM files
    romfiles=("$BASEROMS_DIR"/*.*64)
    if [ ! -e "${romfiles[0]}" ]; then
        emit_fail_msg "Please add one or more *.z64 or *.n64 files to $BASEROMS_DIR before running this script."
        return 1
    fi

    # Process ROMs
    for romfile in "${romfiles[@]}"; do
        ext="${romfile##*.}"
        newname="$BASEROMS_DIR/rom$i.$ext"
        if mv -f "$romfile" "$newname"; then
            echo "Renamed $romfile -> $newname"
            ARGS="$ARGS \"$newname\""
            ((i++))
        else
            emit_fail_msg "Error: Failed to rename $romfile"
            return 1
        fi
    done
}

unzip_assets || { echo "Patching process failed!"; exit 1; }
process_roms || { echo "Patching process failed!"; return 1; }

# Run soh.elf with all ROM arguments
if eval "$GAMEDIR/soh.elf" "$ARGS" > "$GAMEDIR/tools/otrlog.txt"; then
    echo "Patching process complete!"
else
    RET=$?
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
    echo "Patching process failed!"
fi
